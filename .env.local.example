# ==========================================
# Urban Cafe - Environment Variables Guide
# ==========================================
# Duplicate this file and rename it to `.env.local`
# Fill in the values following the instructions below.

# ------------------------------------------
# 1. Supabase Configuration (Required)
# ------------------------------------------
# Find these in your Supabase Dashboard: Project Settings -> API
# NEXT_PUBLIC_SUPABASE_URL: The URL of your Supabase project (e.g., https://your-project-ref.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# NEXT_PUBLIC_SUPABASE_ANON_KEY: The public anon key for standard client-side requests.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY: The secret key for bypassing Row Level Security (RLS) in server API routes.
# **WARNING:** Never expose this key on the client-side!
SUPABASE_SERVICE_ROLE_KEY=


# ------------------------------------------
# 2. Telegram Notifications (Optional, but recommended)
# ------------------------------------------
# Follow instructions provided by @BotFather on Telegram to get your bot token.
TELEGRAM_BOT_TOKEN=

# Send a message to your bot and then visit:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates to find your chat ID.
TELEGRAM_CHAT_ID=
